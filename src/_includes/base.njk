<!doctype html>
<html lang="{{ site.language or 'en' }}">
  <head>
    {% set metaTitle = meta_title or title or site.name %}
    {% if metaTitle == site.name %}
      {% set pageTitle = metaTitle %}
    {% else %}
      {% set pageTitle = metaTitle + " | " + site.name %}
    {% endif %}
    {% set rawMetaDescription = meta_description or description or abstract or site.defaultDescription %}
    {% set metaDescriptionText = rawMetaDescription | striptags | trim %}
    {% if metaDescriptionText.length > 180 %}
      {% set metaDescription = metaDescriptionText.slice(0, 177).trim() + "..." %}
    {% else %}
      {% set metaDescription = metaDescriptionText %}
    {% endif %}
    {% set canonicalPath = canonical_path or page.url or "/" %}
    {% set canonicalUrl = canonical_url or (site.url + canonicalPath) %}
    {% set metaImagePath = meta_image or image or featured_image or site.defaultImage %}
    {% if metaImagePath and metaImagePath[0] == "/" %}
      {% set metaImageUrl = site.url + metaImagePath %}
    {% else %}
      {% set metaImageUrl = metaImagePath %}
    {% endif %}
    {% set pageType = meta_type or "website" %}
    {% set schemaType = schema_type or (meta_type == "article" and "ScholarlyArticle" or "WebPage") %}
    {% set logoImageUrl = site.url + site.defaultImage %}
    {% set faviconPath = site.favicon or "/favicon-32x32.png" %}

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{ pageTitle }}</title>
    <meta name="description" content="{{ metaDescription }}" />
    <meta name="author" content="{{ site.author }}" />
    {% if noindex %}
      <meta name="robots" content="noindex, nofollow" />
    {% else %}
      <meta name="robots" content="index, follow" />
    {% endif %}
    <meta name="theme-color" content="{{ site.themeColor }}" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png?v=3" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png?v=3" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png?v=3" />
    <link rel="shortcut icon" href="{{ faviconPath }}?v=3" type="image/png" />
    <link rel="canonical" href="{{ canonicalUrl }}" />
    <link rel="alternate" hreflang="{{ site.language or 'en' }}" href="{{ canonicalUrl }}" />
    <link rel="alternate" hreflang="x-default" href="{{ site.url }}/" />

    <meta property="og:type" content="{{ pageType }}" />
    <meta property="og:site_name" content="{{ site.name }}" />
    <meta property="og:locale" content="{{ site.locale }}" />
    <meta property="og:title" content="{{ pageTitle }}" />
    <meta property="og:description" content="{{ metaDescription }}" />
    <meta property="og:url" content="{{ canonicalUrl }}" />
    <meta property="og:image" content="{{ metaImageUrl }}" />
    <meta property="og:image:alt" content="{{ meta_image_alt or pageTitle }}" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="{{ pageTitle }}" />
    <meta name="twitter:description" content="{{ metaDescription }}" />
    <meta name="twitter:image" content="{{ metaImageUrl }}" />
    {% if site.twitterHandle %}
      <meta name="twitter:site" content="{{ site.twitterHandle }}" />
    {% endif %}

    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": {{ schemaType | json | safe }},
        "@id": {{ canonicalUrl | json | safe }},
        "name": {{ metaTitle | json | safe }},
        "headline": {{ metaTitle | json | safe }},
        "description": {{ metaDescription | json | safe }},
        "url": {{ canonicalUrl | json | safe }},
        "inLanguage": {{ (site.language or "en") | json | safe }},
        "image": {{ metaImageUrl | json | safe }},
        "mainEntityOfPage": {{ canonicalUrl | json | safe }},
        {% if meta_type == "article" and publication_link %}
        "sameAs": {{ publication_link | json | safe }},
        {% endif %}
        "author": {
          "@type": "Person",
          "name": {{ site.author | json | safe }}
        },
        "publisher": {
          "@type": "Organization",
          "name": {{ site.name | json | safe }},
          "logo": {
            "@type": "ImageObject",
            "url": {{ logoImageUrl | json | safe }}
          }
        }
      }
    </script>

    {% if page.url and page.url != "/" %}
      {% if page.url.indexOf("/posts/") == 0 %}
        {% set breadcrumbSecondName = "Publications & Projects" %}
        {% set breadcrumbSecondUrl = site.url + "/publications-projects/" %}
      {% else %}
        {% set breadcrumbSecondName = metaTitle %}
        {% set breadcrumbSecondUrl = canonicalUrl %}
      {% endif %}

      <script type="application/ld+json">
        {
          "@context": "https://schema.org",
          "@type": "BreadcrumbList",
          "itemListElement": [
            {
              "@type": "ListItem",
              "position": 1,
              "name": {{ "Home" | json | safe }},
              "item": {{ (site.url + "/") | json | safe }}
            },
            {
              "@type": "ListItem",
              "position": 2,
              "name": {{ breadcrumbSecondName | json | safe }},
              "item": {{ breadcrumbSecondUrl | json | safe }}
            }{% if page.url.indexOf("/posts/") == 0 %},
            {
              "@type": "ListItem",
              "position": 3,
              "name": {{ metaTitle | json | safe }},
              "item": {{ canonicalUrl | json | safe }}
            }{% endif %}
          ]
        }
      </script>
    {% endif %}
    <link rel="stylesheet" href="/assets/css/styles.css" />
    <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
  </head>

  <body{% if home_theme %} class="home-theme-{{ home_theme }}"{% endif %}>
    <header class="site-header">
      <div class="wrap header-inner">
        <a class="brand" href="/" aria-label="Deep-Tech home">
          <img src="{% if home_theme == 'alt' %}/assets/img/TechnoGenesispreview.png{% else %}/assets/img/otherlogo1.png{% endif %}" alt="Deep Tech logo" />
        </a>

        <button
          class="menu-toggle"
          type="button"
          aria-expanded="false"
          aria-controls="primary-navigation"
          aria-label="Toggle navigation"
        >
          <img class="menu-toggle-icon" src="/assets/img/menu.png" alt="" aria-hidden="true" />
          <span class="menu-toggle-label">Menu</span>
        </button>

        <nav class="nav" id="primary-navigation" aria-label="Primary">
          <a href="/" {% if page.url == "/" %}aria-current="page"{% endif %}>Home</a>
          <a href="/services/" {% if page.url == "/services/" %}aria-current="page"{% endif %}>Services</a>
          <a href="/about/" {% if page.url == "/about/" %}aria-current="page"{% endif %}>About</a>
          <a href="/industries-clients/" {% if page.url == "/industries-clients/" %}aria-current="page"{% endif %}>Industries &amp; Use cases</a>
          <a href="/publications-projects/" {% if page.url == "/publications-projects/" %}aria-current="page"{% endif %}>Publications &amp; Projects</a>
        </nav>

        <div class="header-actions">
          <a class="cta-pill" href="/contact/">Contact</a>
        </div>
      </div>
    </header>

    <main class="wrap">
      {{ content | safe }}
    </main>

    <footer class="site-footer">
      <div class="wrap footer-inner">
        <div class="footer-top">
          <div class="footer-brand">
            <a class="footer-logo-link" href="/" aria-label="Patent Engineer home">
              <img src="{% if home_theme == 'alt' %}/assets/img/TechnoGenesispreview.png{% else %}/assets/img/otherlogo1.png{% endif %}" alt="Patent Engineer logo" />
            </a>
            
          </div>

          <div class="footer-contact">
            <p class="footer-contact-label">Contact</p>
            <p class="footer-contact-location">Paris, France</p>
            <a href="mailto:contact@technogenesis.fr">contact@technogenesis.fr</a>
            <a class="footer-contact-phone" href="tel:+33648938972">+33 6 48 93 89 72</a>
          </div>
        </div>

        <div class="footer-bottom">
          <div class="footer-bottom-left">
            <small>© {{ "now" | date("yyyy") }} Meletis Mexis. All Rights Reserved.</small>
            <a class="footer-privacy-link" href="/privacy-policy/" {% if page.url == "/privacy-policy/" %}aria-current="page"{% endif %}>Privacy Policy</a>
          </div>
          <small>Powered by Tia William</small>
        </div>
      </div>
    </footer>

    <script>
      if (window.netlifyIdentity) {
        window.netlifyIdentity.on("init", () => {
          const hash = window.location.hash || "";
          if (
            hash.includes("invite_token=") ||
            hash.includes("recovery_token=") ||
            hash.includes("confirmation_token=")
          ) {
            window.netlifyIdentity.open();
          }
        });
      }

      const siteHeader = document.querySelector(".site-header");
      const menuToggle = document.querySelector(".menu-toggle");
      const primaryNav = document.querySelector("#primary-navigation");
      const headerActions = document.querySelector(".header-actions");

      if (siteHeader && menuToggle && primaryNav && headerActions) {
        const setMenuState = (isOpen) => {
          siteHeader.classList.toggle("menu-open", isOpen);
          menuToggle.setAttribute("aria-expanded", String(isOpen));
        };

        const closeMenu = () => setMenuState(false);

        menuToggle.addEventListener("click", () => {
          const isOpen = menuToggle.getAttribute("aria-expanded") === "true";
          setMenuState(!isOpen);
        });

        primaryNav.querySelectorAll("a").forEach((link) => {
          link.addEventListener("click", closeMenu);
        });

        window.addEventListener("keydown", (event) => {
          if (event.key === "Escape") {
            closeMenu();
            menuToggle.focus();
          }
        });

        window.addEventListener("resize", () => {
          if (window.innerWidth > 980) {
            closeMenu();
          }
        });
      }

      // Prevent stale #services hashes from forcing auto-scroll on refresh.
      if (window.location.pathname === "/" && window.location.hash === "#services") {
        history.replaceState(null, "", window.location.pathname + window.location.search);
        window.addEventListener(
          "load",
          () => window.scrollTo({ top: 0, left: 0, behavior: "auto" }),
          { once: true }
        );
      }

      document.documentElement.classList.add("reveal-ready");

      const revealItems = document.querySelectorAll("[data-reveal]");

      if (revealItems.length) {
        if ("IntersectionObserver" in window) {
          const revealObserver = new IntersectionObserver(
            (entries, observer) => {
              entries.forEach((entry) => {
                if (!entry.isIntersecting) return;

                entry.target.classList.add("is-visible");
                observer.unobserve(entry.target);
              });
            },
            { threshold: 0.16, rootMargin: "0px 0px -8% 0px" }
          );

          revealItems.forEach((item) => revealObserver.observe(item));
        } else {
          revealItems.forEach((item) => item.classList.add("is-visible"));
        }
      }

      const slowLinks = document.querySelectorAll("[data-slow-scroll]");
      const easeInOut = (t) => (t < 0.5 ? 4 * t * t * t : 1 - Math.pow(-2 * t + 2, 3) / 2);

      slowLinks.forEach((link) => {
        link.addEventListener("click", (event) => {
          const targetId = link.getAttribute("href");
          if (!targetId || !targetId.startsWith("#")) return;

          const target = document.querySelector(targetId);
          if (!target) return;

          event.preventDefault();

          const startY = window.scrollY;
          const targetY = target.getBoundingClientRect().top + window.scrollY - 16;
          const duration = 1200;
          const startTime = performance.now();

          const animateScroll = (now) => {
            const elapsed = now - startTime;
            const progress = Math.min(elapsed / duration, 1);
            const eased = easeInOut(progress);
            const nextY = startY + (targetY - startY) * eased;
            window.scrollTo(0, nextY);

            if (progress < 1) {
              requestAnimationFrame(animateScroll);
            }
          };

          requestAnimationFrame(animateScroll);
        });
      });

      const servicesGrid = document.querySelector(".services-grid");

      if (servicesGrid && "IntersectionObserver" in window) {
        servicesGrid.classList.add("observe-inview");

        const servicesObserver = new IntersectionObserver(
          (entries, observer) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting) return;

              servicesGrid.classList.add("is-visible");
              observer.unobserve(entry.target);
            });
          },
          { threshold: 0.2 }
        );

        servicesObserver.observe(servicesGrid);
      }

      const whyWork = document.querySelector(".why-work");

      if (whyWork && "IntersectionObserver" in window) {
        whyWork.classList.add("observe-inview");

        const whyWorkObserver = new IntersectionObserver(
          (entries, observer) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting) return;

              whyWork.classList.add("is-visible");
              observer.unobserve(entry.target);
            });
          },
          { threshold: 0.28 }
        );

        whyWorkObserver.observe(whyWork);
      }

      const articlesPreview = document.querySelector(".articles-preview");

      if (articlesPreview && "IntersectionObserver" in window) {
        articlesPreview.classList.add("observe-inview");

        const publicationsObserver = new IntersectionObserver(
          (entries, observer) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting) return;

              articlesPreview.classList.add("is-visible");
              observer.unobserve(entry.target);
            });
          },
          { threshold: 0.2 }
        );

        publicationsObserver.observe(articlesPreview);
      }

      const servicesListGrid = document.querySelector(".services-list-grid");

      if (servicesListGrid && "IntersectionObserver" in window) {
        servicesListGrid.classList.add("observe-inview");

        const serviceCards = servicesListGrid.querySelectorAll(".services-feature-card");
        serviceCards.forEach((card, index) => {
          card.style.setProperty("--services-delay", `${index * 180}ms`);
        });

        const servicesListObserver = new IntersectionObserver(
          (entries, observer) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting) return;

              servicesListGrid.classList.add("is-visible");
              observer.unobserve(entry.target);
            });
          },
          { threshold: 0.2 }
        );

        servicesListObserver.observe(servicesListGrid);
      }

      const highlightsAchievements = document.querySelector("#highlights-achievements");

      if (highlightsAchievements && "IntersectionObserver" in window) {
        highlightsAchievements.classList.add("observe-inview");

        const revealItems = highlightsAchievements.querySelectorAll(
          ".about-card li span"
        );

        revealItems.forEach((item, index) => {
          item.style.setProperty("--reveal-delay", `${index * 220}ms`);
        });

        const highlightsObserver = new IntersectionObserver(
          (entries, observer) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting) return;

              highlightsAchievements.classList.add("is-visible");
              observer.unobserve(entry.target);
            });
          },
          { threshold: 0.2 }
        );

        highlightsObserver.observe(highlightsAchievements);
      }

      const achievementsStrip = document.querySelector("#highlights-achievements .about-highlights-strip");

      if (achievementsStrip && "IntersectionObserver" in window) {
        achievementsStrip.classList.add("observe-inview");

        const stripItems = achievementsStrip.querySelectorAll(".about-highlight-item p");
        stripItems.forEach((item, index) => {
          item.style.setProperty("--reveal-delay", `${index * 220}ms`);
        });

        const stripObserver = new IntersectionObserver(
          (entries, observer) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting) return;

              achievementsStrip.classList.add("is-visible");
              observer.unobserve(entry.target);
            });
          },
          { threshold: 0.3 }
        );

        stripObserver.observe(achievementsStrip);
      }

    </script>
  </body>
</html>

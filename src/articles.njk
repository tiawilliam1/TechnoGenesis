---
layout: base.njk
title: Publications
description: Technical publications and research references from TechnoGenesis and Meletis Mexis.
meta_title: Scientific and Patent Publications by TechnoGenesis
meta_description: Browse technical publications and research references from TechnoGenesis and Meletis Mexis in photonics, semiconductors, and deep-tech IP.
meta_image: /assets/img/logo.png
meta_image_alt: TechnoGenesis publications listing
schema_type: CollectionPage
pagination:
  data: collections.posts
  size: 1000
permalink: "articles/index.html"
---

<h1>Publications</h1>

{% if collections.posts and collections.posts.length %}
  {% for post in collections.posts %}
    <article class="card">
      {% set publicationLink = post.data.publication_link %}
      {% set publicationFile = post.data.publication_file %}
      {% set publicationTarget = "" %}
      {% if publicationFile %}
        {% set publicationTarget = publicationFile %}
      {% elif publicationLink and (publicationLink | isPublicationTarget) %}
        {% set publicationTarget = publicationLink %}
      {% endif %}
      {% set publicationButtonEnabled = publicationTarget and post.data.publication_button_enabled != false %}
      {% set publicationButtonLabel = post.data.publication_button_label or "Read publication" %}
      <h2>
        {% if publicationButtonEnabled %}
          <a href="{{ publicationTarget }}" target="_blank" rel="noopener noreferrer">{{ post.data.title }}</a>
        {% else %}
          {{ post.data.title }}
        {% endif %}
      </h2>
      {% if post.data.abstract or post.data.description %}<p>{{ post.data.abstract or post.data.description }}</p>{% endif %}
      {% if post.data.image or post.data.featured_image %}
        <img src="{{ post.data.image or post.data.featured_image }}" alt="" />
      {% endif %}
      {% if publicationButtonEnabled %}
        <p><a href="{{ publicationTarget }}" target="_blank" rel="noopener noreferrer">{{ publicationButtonLabel }}</a></p>
      {% endif %}
    </article>
  {% endfor %}
{% else %}
  <p>No publications yet. Add one in <a href="/admin/">Admin</a>.</p>
{% endif %}

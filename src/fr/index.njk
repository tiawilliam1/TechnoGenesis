<section class="articles-preview" id="publications">
  <div class="section-head section-head--publications articles-preview-head">
    <h2>Publications choisies</h2>
    <p class="section-subline">Une sélection d'articles en photonique et semi-conducteurs, et de travaux brevets en physique appliquée.</p>
    <a href="/fr/publications-projects/">Voir toutes les publications →</a>
  </div>

  {% if collections.homePublications and collections.homePublications.length %}
    <div class="cards cards--publications-preview">
      {% for post in collections.homePublications %}
        {% if loop.index0 < 3 %}
          <article class="card publication-preview-card">
            {% set publicationLink = post.data.publication_link %}
            {% set publicationFile = post.data.publication_file %}
            {% set publicationTarget = "" %}
            {% if publicationFile %}
              {% set publicationTarget = publicationFile %}
            {% elif publicationLink and (publicationLink | isPublicationTarget) %}
              {% set publicationTarget = publicationLink %}
            {% endif %}
            {% set publicationButtonEnabled = publicationTarget and post.data.publication_button_enabled != false %}
            {% set publicationButtonLabel = post.data.publication_button_label_fr or post.data.publication_button_label or "Lire la publication" %}
            {% set summaryText = post.data.abstract or post.data.description %}
            <div class="publication-preview-content">
              <h3>
                {% if publicationButtonEnabled %}
                  <a href="{{ publicationTarget }}" target="_blank" rel="noopener noreferrer">{{ post.data.title }}</a>
                {% else %}
                  {{ post.data.title }}
                {% endif %}
              </h3>
              {% if summaryText %}
                <p class="publication-preview-excerpt">{{ summaryText }}</p>
              {% endif %}
            </div>
            {% if publicationButtonEnabled %}
              <a class="publication-preview-link" href="{{ publicationTarget }}" target="_blank" rel="noopener noreferrer">{{ publicationButtonLabel }} →</a>
            {% endif %}
            {% if post.data.image or post.data.featured_image %}
              {% if publicationButtonEnabled %}
              <a class="publication-preview-media" href="{{ publicationTarget }}" target="_blank" rel="noopener noreferrer">
                <img src="{{ post.data.image or post.data.featured_image }}" alt="" />
              </a>
              {% else %}
                <div class="publication-preview-media">
                  <img src="{{ post.data.image or post.data.featured_image }}" alt="" />
                </div>
              {% endif %}
            {% endif %}
          </article>
        {% endif %}
      {% endfor %}
    </div>
  {% else %}
    <p>Aucune publication pour le moment.</p>
  {% endif %}
</section>


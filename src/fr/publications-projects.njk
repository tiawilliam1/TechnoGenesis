---
layout: base.njk
lang: fr
locale: fr_FR
title: Recherche & Publications
description: Production scientifique en photonique, semi-conducteurs et information brevets.
meta_title: Recherche et publications par TechnoGenesis
meta_description: Production scientifique de TechnoGenesis en photonique, semi-conducteurs et information brevets.
meta_image: /assets/img/logo3.png
meta_image_alt: Publications et projets par TechnoGenesis
schema_type: CollectionPage
permalink: /fr/publications-projects/
canonical_path: /fr/publications-projects/
alternate_url: /publications-projects/
home_theme: alt
---

{% set googleScholarUrl = "https://scholar.google.com/citations?hl=en&user=FpvwoYEAAAAJ" %}
{% if collections.posts and collections.posts.length %}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "ItemList",
      "@id": {{ (site.url + page.url + "#publication-list") | json | safe }},
      "name": {{ "Liste des publications TechnoGenesis" | json | safe }},
      "mainEntityOfPage": {{ (site.url + page.url) | json | safe }},
      "itemListOrder": "https://schema.org/ItemListOrderDescending",
      "numberOfItems": {{ collections.posts.length }},
      "itemListElement": [
        {% for post in collections.posts %}
          {% set postUrl = site.url + post.url %}
          {% if post.data.publication_file %}
            {% if post.data.publication_file[0] == "/" %}
              {% set postUrl = site.url + post.data.publication_file %}
            {% else %}
              {% set postUrl = post.data.publication_file %}
            {% endif %}
          {% elif post.data.publication_link and (post.data.publication_link | isPublicationTarget) %}
            {% set postUrl = post.data.publication_link %}
          {% endif %}
          {% set postSummary = post.data.abstract or post.data.description %}
          {% set postImagePath = post.data.image or post.data.featured_image %}
          {% if postImagePath and postImagePath[0] == "/" %}
            {% set postImageUrl = site.url + postImagePath %}
          {% else %}
            {% set postImageUrl = postImagePath %}
          {% endif %}
          {
            "@type": "ListItem",
            "position": {{ loop.index }},
            "item": {
              "@type": "ScholarlyArticle",
              "name": {{ post.data.title | json | safe }},
              "url": {{ postUrl | json | safe }}{% if postSummary %},
              "description": {{ (postSummary | striptags | trim) | json | safe }}{% endif %}{% if postImageUrl %},
              "image": {{ postImageUrl | json | safe }}{% endif %}
            }
          }{% if not loop.last %},{% endif %}
        {% endfor %}
      ]
    }
  </script>
{% endif %}

<section class="publications-page">
  <div class="publications-hero">
    <div class="publications-hero-inner">
      <h1 data-reveal="up">Recherche &amp; Publications</h1>
      <p class="publications-short" data-reveal="up" style="--reveal-delay: 80ms;">
        Production scientifique en photonique, semi-conducteurs et information brevets.
      </p>
    </div>

    <nav class="publications-cta-strip" aria-label="Liens rapides publications">
      <a href="#patent-intelligence-publications" data-reveal="up" style="--reveal-delay: 200ms;">Information brevets</a>
      <a href="#scientific-publications" data-reveal="up" style="--reveal-delay: 280ms;">Photonique &amp; semi-conducteurs</a>
      <a href="#further-insights" data-reveal="up" style="--reveal-delay: 360ms;">Prospectives</a>
    </nav>
  </div>

  <section class="publications-info-section publications-info-section--patent" id="patent-intelligence-publications">
    <div class="publications-info-inner publications-info-inner--patent" data-reveal="up">
      <h2>Publications en information brevets</h2>
      <p class="publications-info-emphasis">
        Élaborées en partenariat avec le monde académique, à l’intersection de l’intelligence brevets et de la recherche en physique appliquée.
      </p>
      <div class="publications-topic-head">
        <p class="publications-topic-label">Collaboration en cours et sujets de soumission</p>
      </div>

      {% if collections.patentPublications and collections.patentPublications.length %}
        <ul class="publications-topic-list">
          {% for post in collections.patentPublications %}
            {% set publicationLink = post.data.publication_link %}
            {% set publicationFile = post.data.publication_file %}
            {% set publicationTarget = "" %}
            {% if publicationFile %}
              {% set publicationTarget = publicationFile %}
            {% elif publicationLink and (publicationLink | isPublicationTarget) %}
              {% set publicationTarget = publicationLink %}
            {% endif %}
            {% set publicationButtonEnabled = publicationTarget and post.data.publication_button_enabled != false %}
            {% set publicationButtonLabel = post.data.publication_button_label_fr or post.data.publication_button_label or "Voir la publication" %}
            {% set publicationImage = post.data.image or post.data.featured_image %}
            {% set publicationBody = post.content or post.templateContent %}
            {% set summaryText = post.data.abstract or post.data.description %}
            {% set typeLabel = post.data.publication_type_fr or (post.data.publication_type == "Conference paper or presentation" and "Conférence ou présentation" or (post.data.publication_type or "Article")) %}
            <li>
              <article class="publication-card publication-card--compact publications-topic-card{% if not publicationImage %} publication-card--no-media{% endif %}">
                <div class="publication-content">
                  {% if post.data.current_collaboration or post.data.current_status %}
                    <span class="publications-topic-status">{{ post.data.current_status or "Document de travail" }}</span>
                  {% endif %}
                  <div class="publication-meta">
                    {% if post.data.publication_year %}
                      <span class="publication-year">{{ post.data.publication_year }}</span>
                    {% endif %}
                    <span class="publication-type-badge">{{ typeLabel }}</span>
                  </div>
                  <h3>{{ post.data.title }}</h3>
                  {% if summaryText or publicationBody or publicationButtonEnabled %}
                    <details class="publications-topic-details">
                      <summary>
                        {% if summaryText %}
                          <span class="publications-topic-description">{{ summaryText }}</span>
                        {% endif %}
                        <span class="publications-topic-toggle">
                          <span class="publications-topic-toggle-more">{% if summaryText %}Voir la description complète{% else %}Voir les détails{% endif %}</span>
                          <span class="publications-topic-toggle-less">Réduire</span>
                        </span>
                      </summary>
                      <div class="publication-body publications-topic-full-description">
                        {% if summaryText %}
                          <p>{{ summaryText }}</p>
                        {% endif %}
                        {% if publicationBody %}
                          {{ publicationBody | safe }}
                        {% endif %}
                        {% if publicationButtonEnabled %}
                          <p class="publication-link-wrap">
                            <a class="publication-link" href="{{ publicationTarget }}" target="_blank" rel="noopener noreferrer">{{ publicationButtonLabel }}</a>
                          </p>
                        {% endif %}
                      </div>
                    </details>
                  {% endif %}
                </div>
                {% if publicationImage %}
                  <a class="publication-media" href="{{ publicationImage }}">
                    <img src="{{ publicationImage }}" alt="" />
                  </a>
                {% endif %}
              </article>
            </li>
          {% endfor %}
        </ul>
      {% else %}
        <ul class="publications-topic-list">
          <li>À compléter</li>
        </ul>
      {% endif %}
    </div>
  </section>

  <section class="publications-info-section publications-info-section--science" id="scientific-publications">
    <div class="publications-info-inner" data-reveal="up">
      <h2>Publications en photonique &amp; semi-conducteurs</h2>
      <p class="publications-info-links">
        Liste complète des publications&nbsp;:
        <a href="{{ googleScholarUrl }}" target="_blank" rel="noopener noreferrer">Meletis / Meletios Mexis - Google Scholar</a>
      </p>
      <ul class="publications-science-highlights">
        <li><strong>21 publications à comité de lecture</strong> en optoélectronique quantique et lasers à semi-conducteurs.</li>
        <li>Parmi les revues&nbsp;: Applied Physics Letters, Physical Review Letters et Journal of Applied Physics.</li>
      </ul>

      {% if collections.photonicsPublications and collections.photonicsPublications.length %}
        <p class="publications-selected-label">Publications sélectionnées</p>
        <div class="publications-grid publications-grid--section" id="publications-grid">
          {% for post in collections.photonicsPublications %}
          {% set publicationLink = post.data.publication_link %}
          {% set publicationFile = post.data.publication_file %}
          {% set publicationTarget = "" %}
          {% if publicationFile %}
            {% set publicationTarget = publicationFile %}
          {% elif publicationLink and (publicationLink | isPublicationTarget) %}
            {% set publicationTarget = publicationLink %}
          {% endif %}
          {% set publicationButtonEnabled = publicationTarget and post.data.publication_button_enabled != false %}
          {% set publicationButtonLabel = post.data.publication_button_label_fr or post.data.publication_button_label or "Voir la publication" %}
          {% set publicationImage = post.data.image or post.data.featured_image %}
          {% set publicationBody = post.content or post.templateContent %}
          {% set typeLabel = post.data.publication_type_fr or (post.data.publication_type == "Conference paper or presentation" and "Conférence ou présentation" or (post.data.publication_type or "Article")) %}
          <article
            class="publication-card{% if not publicationImage %} publication-card--no-media{% endif %}"
            data-index="{{ loop.index0 }}"
            data-title="{{ (post.data.title or '') | lower | escape }}"
          >
            <div class="publication-content">
              <div class="publication-meta">
                {% if post.data.publication_year %}
                  <span class="publication-year">{{ post.data.publication_year }}</span>
                {% endif %}
                <span class="publication-type-badge">{{ typeLabel }}</span>
              </div>
              <h3>{{ post.data.title }}</h3>
              {% if post.data.abstract or post.data.description %}
                <p>{{ post.data.abstract or post.data.description }}</p>
              {% endif %}
              {% if publicationBody %}
                <div class="publication-body">
                  {{ publicationBody | safe }}
                </div>
              {% endif %}
              {% if publicationButtonEnabled %}
                <p class="publication-link-wrap">
                  <a class="publication-link" href="{{ publicationTarget }}" target="_blank" rel="noopener noreferrer">
                    {{ publicationButtonLabel }}
                  </a>
                </p>
              {% endif %}
            </div>
            {% if publicationImage %}
              <a class="publication-media js-publication-image" href="{{ publicationImage }}" data-image-src="{{ publicationImage }}" data-image-alt="{{ post.data.title | escape }}" aria-label="Ouvrir l’aperçu de l’image pour {{ post.data.title }}">
                <img src="{{ publicationImage }}" alt="" />
              </a>
            {% endif %}
          </article>
        {% endfor %}
      </div>
      <nav class="publications-pagination" id="publications-pagination" aria-label="Pages des publications"></nav>
      <dialog class="publication-lightbox" id="publication-lightbox" aria-label="Aperçu de l’image de publication">
        <button type="button" class="publication-lightbox-close" id="publication-lightbox-close" aria-label="Fermer l’aperçu">×</button>
        <img id="publication-lightbox-image" src="" alt="" />
      </dialog>
      <script>
        (() => {
          const grid = document.getElementById("publications-grid");
          const pagination = document.getElementById("publications-pagination");
          const lightbox = document.getElementById("publication-lightbox");
          const lightboxImage = document.getElementById("publication-lightbox-image");
          const lightboxClose = document.getElementById("publication-lightbox-close");
          if (!grid || !pagination) return;

          const cards = Array.from(grid.querySelectorAll(".publication-card"));
          const pageSize = 3;
          let orderedCards = [...cards];
          let currentPage = 1;

          const renderPagination = () => {
            const totalPages = Math.max(1, Math.ceil(orderedCards.length / pageSize));
            pagination.innerHTML = "";

            if (totalPages <= 1) {
              pagination.hidden = true;
              return;
            }

            pagination.hidden = false;

            for (let page = 1; page <= totalPages; page += 1) {
              const button = document.createElement("button");
              button.type = "button";
              button.className = "publications-page-btn";
              button.textContent = String(page);
              button.setAttribute("aria-label", `Aller à la page ${page}`);

              if (page === currentPage) {
                button.classList.add("is-active");
                button.setAttribute("aria-current", "page");
              }

              button.addEventListener("click", () => {
                currentPage = page;
                renderCards();
              });

              pagination.appendChild(button);
            }
          };

          const renderCards = () => {
            const start = (currentPage - 1) * pageSize;
            const end = start + pageSize;

            orderedCards.forEach((card, index) => {
              grid.appendChild(card);
              card.hidden = index < start || index >= end;
            });

            renderPagination();
          };

          const openLightbox = (event) => {
            if (!lightbox || !lightboxImage) return;

            event.preventDefault();
            const link = event.currentTarget;
            const src = link.dataset.imageSrc || link.getAttribute("href");
            if (!src) return;

            lightboxImage.src = src;
            lightboxImage.alt = link.dataset.imageAlt || "Aperçu de l’image de publication";

            if (typeof lightbox.showModal === "function") {
              if (!lightbox.open) lightbox.showModal();
              return;
            }

            window.open(src, "_blank", "noopener");
          };

          const bindImagePreview = () => {
            const imageLinks = grid.querySelectorAll(".js-publication-image");
            imageLinks.forEach((link) => {
              if (link.dataset.lightboxBound === "true") return;
              link.dataset.lightboxBound = "true";
              link.addEventListener("click", openLightbox);
            });
          };

          const showChronologicalCards = () => {
            orderedCards = [...cards];
            currentPage = 1;
            renderCards();
            bindImagePreview();
          };

          if (lightboxClose && lightbox) {
            lightboxClose.addEventListener("click", () => lightbox.close());
            lightbox.addEventListener("click", (event) => {
              if (event.target === lightbox) lightbox.close();
            });
          }

          showChronologicalCards();
        })();
      </script>
    {% else %}
      <p class="publications-empty">Aucune publication pour le moment.</p>
    {% endif %}
    </div>
  </section>

  <section class="publications-info-section publications-info-section--insights" id="further-insights">
    <div class="publications-info-inner" data-reveal="up">
      <h2>Prospectives</h2>
      <p class="publications-info-emphasis">
        Perspectives complémentaires, mises à jour, interventions et notes de recherche appliquée liées à l’intelligence brevets deep-tech.
      </p>

      {% if collections.furtherInsightsPublications and collections.furtherInsightsPublications.length %}
        <div class="publications-grid publications-grid--section">
          {% for post in collections.furtherInsightsPublications %}
            {% set publicationLink = post.data.publication_link %}
            {% set publicationFile = post.data.publication_file %}
            {% set publicationTarget = "" %}
            {% if publicationFile %}
              {% set publicationTarget = publicationFile %}
            {% elif publicationLink and (publicationLink | isPublicationTarget) %}
              {% set publicationTarget = publicationLink %}
            {% endif %}
            {% set publicationButtonEnabled = publicationTarget and post.data.publication_button_enabled != false %}
            {% set publicationButtonLabel = post.data.publication_button_label_fr or post.data.publication_button_label or "Voir la publication" %}
            {% set publicationImage = post.data.image or post.data.featured_image %}
            {% set publicationBody = post.content or post.templateContent %}
            {% set typeLabel = post.data.publication_type_fr or (post.data.publication_type == "Conference paper or presentation" and "Conférence ou présentation" or (post.data.publication_type or "Prospective")) %}
            <article class="publication-card{% if not publicationImage %} publication-card--no-media{% endif %}">
              <div class="publication-content">
                <div class="publication-meta">
                  {% if post.data.publication_year %}
                    <span class="publication-year">{{ post.data.publication_year }}</span>
                  {% endif %}
                  <span class="publication-type-badge">{{ typeLabel }}</span>
                </div>
                <h3>{{ post.data.title }}</h3>
                {% if post.data.abstract or post.data.description %}
                  <p>{{ post.data.abstract or post.data.description }}</p>
                {% endif %}
                {% if publicationBody %}
                  <details class="publications-insight-details">
                    <summary>Lire le texte complet</summary>
                    <div class="publication-body publications-insight-full-text">
                      {{ publicationBody | safe }}
                    </div>
                  </details>
                {% endif %}
                {% if publicationButtonEnabled %}
                  <p class="publication-link-wrap">
                    <a class="publication-link" href="{{ publicationTarget }}" target="_blank" rel="noopener noreferrer">
                      {{ publicationButtonLabel }}
                    </a>
                  </p>
                {% endif %}
              </div>
              {% if publicationImage %}
                <a class="publication-media js-publication-image" href="{{ publicationImage }}" data-image-src="{{ publicationImage }}" data-image-alt="{{ post.data.title | escape }}" aria-label="Ouvrir l’aperçu de l’image pour {{ post.data.title }}">
                  <img src="{{ publicationImage }}" alt="" />
                </a>
              {% endif %}
            </article>
          {% endfor %}
        </div>
      {% else %}
        <p class="publications-empty">Aucune prospective pour le moment.</p>
      {% endif %}
    </div>
  </section>
</section>

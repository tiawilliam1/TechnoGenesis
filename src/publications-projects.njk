---
layout: base.njk
title: Publications & Projects
permalink: /publications-projects/
home_theme: alt
---

{% set googleScholarUrl = "https://scholar.google.com/citations?hl=en&user=FpvwoYEAAAAJ" %}

<section class="publications-page">
  <div class="publications-hero">
    <div class="publications-hero-inner">
      <h1 data-reveal="up">Research and Publications</h1>
      <p class="publications-short" data-reveal="up" style="--reveal-delay: 80ms;">
        Research, analysis, and technical insight for deep-tech IP strategy.
      </p>
    </div>

    <nav class="publications-cta-strip" aria-label="Publications quick links">
      <a href="#patent-intelligence-publications" data-reveal="up" style="--reveal-delay: 200ms;">Current Work</a>
      <a href="#scientific-publications" data-reveal="up" style="--reveal-delay: 280ms;">Publication Link</a>
      <a href="#all-publications" data-reveal="up" style="--reveal-delay: 360ms;">View Publications</a>
    </nav>
  </div>

  <p class="publications-update-note" data-reveal="up" style="--reveal-delay: 120ms;">
    <span class="publications-update-symbol" aria-hidden="true">⚠</span>
    Updated regularly: stay tuned for novel insights at the intersection of scientific research and patent information.
  </p>

  <section class="publications-info-section publications-info-section--patent" id="patent-intelligence-publications">
    <div class="publications-info-inner publications-info-inner--patent" data-reveal="up">
      <h2>Publications in Patent Information &amp; IP Intelligence</h2>
      <p class="publications-info-emphasis">
        <span class="publications-brand-name">TechnoGenesis</span> actively collaborates with academic partners on scientific publications at the intersection of deep-tech innovation and patent intelligence.
      </p>
      <p class="publications-topic-label">Current collaboration and submission topics</p>

      {% if collections.posts and collections.posts.length %}
        <ul class="publications-topic-list">
          {% for post in collections.posts | reverse %}
            {% if loop.index0 < 5 %}
              <li>{{ post.data.title }}</li>
            {% endif %}
          {% endfor %}
        </ul>
      {% else %}
        <ul class="publications-topic-list">
          <li>Advanced search methodology in patent information.</li>
          <li>Deep-tech prior-art intelligence and claim interpretation.</li>
          <li>Academic collaboration topics in patent analytics.</li>
        </ul>
      {% endif %}
    </div>
  </section>

  <section class="publications-info-section publications-info-section--science" id="scientific-publications">
    <div class="publications-info-inner" data-reveal="up">
      <h2>Scientific Publications in Photonics &amp; Semiconductors</h2>
      <p class="publications-info-links">
        Full publication list:
        <a href="{{ googleScholarUrl }}" target="_blank" rel="noopener noreferrer">Meletis / Meletios Mexis - Google Scholar</a>
      </p>
      <ul class="publications-science-highlights">
        <li><strong>21 peer-reviewed publications</strong> in quantum optoelectronics, GaN-based devices, and semiconductor lasers.</li>
        <li>Selected highlights include Applied Physics Letters, Physical Review Letters, and Journal of Applied Physics.</li>
      </ul>
    </div>
  </section>

  <section class="publications-section publications-section--list" id="all-publications">
    <div class="publications-head" data-reveal="up">
      <h2>All Publications</h2>
      <p>Selected outputs spanning patent intelligence, deep-tech analysis, and strategic interpretation.</p>
    </div>

    {% if collections.posts and collections.posts.length %}
      <div class="publications-toolbar">
        <label for="publications-sort">Arrange by</label>
        <select id="publications-sort" class="publications-sort" aria-label="Arrange publications">
          <option value="newest">Newest first</option>
          <option value="oldest">Oldest first</option>
          <option value="title-asc">Title A-Z</option>
          <option value="title-desc">Title Z-A</option>
        </select>
      </div>

      <div class="publications-grid" id="publications-grid">
        {% for post in collections.posts | reverse %}
          {% set publicationUrl = post.data.publication_link or post.url %}
          {% set publicationImage = post.data.image or post.data.featured_image %}
          <article
            class="publication-card"
            data-index="{{ loop.index0 }}"
            data-title="{{ (post.data.title or '') | lower | escape }}"
          >
            <div class="publication-content">
              <h3>{{ post.data.title }}</h3>
              {% if post.data.abstract or post.data.description %}
                <p>{{ post.data.abstract or post.data.description }}</p>
              {% endif %}
              <p class="publication-link-wrap">
                <a class="publication-link" href="{{ publicationUrl }}" {% if post.data.publication_link %}target="_blank" rel="noopener noreferrer"{% endif %}>
                  View publication
                </a>
              </p>
            </div>
            {% if publicationImage %}
              <a class="publication-media js-publication-image" href="{{ publicationImage }}" data-image-src="{{ publicationImage }}" data-image-alt="{{ post.data.title | escape }}" aria-label="Open image preview for {{ post.data.title }}">
                <img src="{{ publicationImage }}" alt="" />
              </a>
            {% endif %}
          </article>
        {% endfor %}
      </div>
      <nav class="publications-pagination" id="publications-pagination" aria-label="Publications pages"></nav>
      <dialog class="publication-lightbox" id="publication-lightbox" aria-label="Publication image preview">
        <button type="button" class="publication-lightbox-close" id="publication-lightbox-close" aria-label="Close image preview">×</button>
        <img id="publication-lightbox-image" src="" alt="" />
      </dialog>
      <script>
        (() => {
          const grid = document.getElementById("publications-grid");
          const sortSelect = document.getElementById("publications-sort");
          const pagination = document.getElementById("publications-pagination");
          const lightbox = document.getElementById("publication-lightbox");
          const lightboxImage = document.getElementById("publication-lightbox-image");
          const lightboxClose = document.getElementById("publication-lightbox-close");
          if (!grid || !sortSelect || !pagination) return;

          const cards = Array.from(grid.querySelectorAll(".publication-card"));
          const pageSize = 3;
          let orderedCards = [...cards];
          let currentPage = 1;

          const renderPagination = () => {
            const totalPages = Math.max(1, Math.ceil(orderedCards.length / pageSize));
            pagination.innerHTML = "";

            if (totalPages <= 1) {
              pagination.hidden = true;
              return;
            }

            pagination.hidden = false;

            for (let page = 1; page <= totalPages; page += 1) {
              const button = document.createElement("button");
              button.type = "button";
              button.className = "publications-page-btn";
              button.textContent = String(page);
              button.setAttribute("aria-label", `Go to page ${page}`);

              if (page === currentPage) {
                button.classList.add("is-active");
                button.setAttribute("aria-current", "page");
              }

              button.addEventListener("click", () => {
                currentPage = page;
                renderCards();
              });

              pagination.appendChild(button);
            }
          };

          const renderCards = () => {
            const start = (currentPage - 1) * pageSize;
            const end = start + pageSize;

            orderedCards.forEach((card, index) => {
              grid.appendChild(card);
              card.hidden = index < start || index >= end;
            });

            renderPagination();
          };

          const openLightbox = (event) => {
            if (!lightbox || !lightboxImage) return;

            event.preventDefault();
            const link = event.currentTarget;
            const src = link.dataset.imageSrc || link.getAttribute("href");
            if (!src) return;

            lightboxImage.src = src;
            lightboxImage.alt = link.dataset.imageAlt || "Publication image preview";

            if (typeof lightbox.showModal === "function") {
              if (!lightbox.open) lightbox.showModal();
              return;
            }

            window.open(src, "_blank", "noopener");
          };

          const bindImagePreview = () => {
            const imageLinks = grid.querySelectorAll(".js-publication-image");
            imageLinks.forEach((link) => {
              if (link.dataset.lightboxBound === "true") return;
              link.dataset.lightboxBound = "true";
              link.addEventListener("click", openLightbox);
            });
          };

          const sortCards = (mode) => {
            orderedCards = [...cards];

            orderedCards.sort((a, b) => {
              const aIdx = Number(a.dataset.index || 0);
              const bIdx = Number(b.dataset.index || 0);
              const aTitle = String(a.dataset.title || "");
              const bTitle = String(b.dataset.title || "");

              if (mode === "oldest") return bIdx - aIdx;
              if (mode === "title-asc") return aTitle.localeCompare(bTitle);
              if (mode === "title-desc") return bTitle.localeCompare(aTitle);
              return aIdx - bIdx; // newest first
            });

            currentPage = 1;
            renderCards();
            bindImagePreview();
          };

          if (lightboxClose && lightbox) {
            lightboxClose.addEventListener("click", () => lightbox.close());
            lightbox.addEventListener("click", (event) => {
              if (event.target === lightbox) lightbox.close();
            });
          }

          sortSelect.addEventListener("change", () => sortCards(sortSelect.value));
          sortCards(sortSelect.value);
        })();
      </script>
    {% else %}
      <p class="publications-empty">No publications yet.</p>
    {% endif %}
  </section>
</section>

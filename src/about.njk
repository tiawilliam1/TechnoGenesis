---
layout: base.njk
title: About Me
description: Profile, scientific background, and deep-tech patent expertise of Meletis Mexis, founder of TechnoGenesis.
meta_title: About Meletis Mexis, Founder of TechnoGenesis
meta_description: Scientific and patent-information profile of Meletis Mexis, combining photonics, semiconductor, and quantum expertise with strategic IP analysis.
meta_image: /assets/img/MeletisPhoto.jpg
meta_image_alt: Meletis Mexis profile photo
schema_type: ProfilePage
permalink: /about/
home_theme: alt
---

<section class="about-page">
  <div class="about-hero about-hero--cover">
    <div class="about-hero-inner">
      <h1 data-reveal="up">{{ about.page_title }}</h1>
      <p class="about-short" data-reveal="up" style="--reveal-delay: 120ms;">{{ about.short_intro }}</p>
    </div>

    <nav class="about-cta-strip" aria-label="About quick links">
      <a href="#opening" data-reveal="up" style="--reveal-delay: 200ms;">Founder</a>
      <a href="#career-timeline" data-reveal="up" style="--reveal-delay: 280ms;">Career Timeline</a>
    </nav>
  </div>

  <section class="about-section about-opening-section" id="opening">
    <div class="about-opening-layout">
      <header class="about-opening-head" data-reveal="left">
        <div class="about-opening-title">
          <h2>{{ about.full_name }}</h2>
          <p class="about-role">{{ about.role }}</p>
        </div>
      </header>

      <div class="about-opening-story" data-reveal="up" style="--reveal-delay: 80ms;">
        <p class="about-opening-paragraph">{{ about.opening_paragraph }}</p>
        {% if about.quick_facts and about.quick_facts.length %}
          <div class="about-opening-facts" aria-label="{{ about.quick_facts_title }}">
            {% for item in about.quick_facts %}
              <span class="about-opening-fact" data-reveal="soft" style="--reveal-delay: {{ 180 + (loop.index0 * 70) }}ms;">{{ item }}</span>
            {% endfor %}
          </div>
        {% endif %}
      </div>

      <aside class="about-opening-aside" data-reveal="right" style="--reveal-delay: 120ms;">
        <article class="about-opening-hero-card">
          <figure class="about-opening-avatar">
            <img
              src="{{ about.profile_image or '/assets/img/Profilepicfiller.png' }}"
              alt="{{ about.profile_image_alt or 'Profile picture placeholder' }}"
              loading="lazy"
              decoding="async"
            />
          </figure>
          <p class="about-opening-hero-tag">Your technical IP Partner</p>
          <p class="about-opening-keyline">{{ about.opening_keyline }}</p>
          <a class="about-opening-consult" href="/contact/">Book a Consultation</a>
        </article>
      </aside>
    </div>
  </section>

  <section class="about-section about-timeline-section" id="career-timeline">
    <div class="about-section-head" data-reveal="up">
      <h2>{{ about.career_timeline_title }}</h2>
      <p>{{ about.career_timeline_subline }}</p>
    </div>
    <ol class="about-timeline-list">
      {% for item in about.career_timeline %}
        <li class="about-timeline-item" data-reveal="soft" style="--reveal-delay: {{ loop.index0 * 80 }}ms;">
          <p class="about-timeline-year">{{ item.year }}</p>
          <article class="about-timeline-card">
            <h3>{{ item.role }}</h3>
            <p>{{ item.highlights }}</p>
          </article>
        </li>
      {% endfor %}
    </ol>
  </section>

</section>
